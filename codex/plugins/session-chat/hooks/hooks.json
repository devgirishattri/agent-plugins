{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$TMUX\" ] && tmux source-file \"$PLUGIN_ROOT/scripts/dispatch-tmux.conf\" 2>/dev/null; exit 0",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash \"$PLUGIN_ROOT/scripts/auto-name-pane.sh\"",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$PLUGIN_ROOT/scripts/detect-incoming-message.sh\"",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$PLUGIN_ROOT/scripts/detect-incoming-message.sh\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
