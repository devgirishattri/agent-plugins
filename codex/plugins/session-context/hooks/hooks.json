{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "SESSION_CONTEXT_HOME=\"${SESSION_CONTEXT_HOME:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)/tmp/contexts}\" bash \"${CODEX_PLUGIN_ROOT:-$(ls -td \"$HOME\"/.codex/plugins/cache/girishattri-plugins/session-context/*/ 2>/dev/null | head -1)}\"/scripts/detect-snapshots.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
