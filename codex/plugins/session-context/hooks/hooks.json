{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "SESSION_CONTEXT_HOME=\"${SESSION_CONTEXT_HOME:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)/tmp/contexts}\" bash \"$PLUGIN_ROOT/scripts/detect-snapshots.sh\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
