# Repo-wide shellcheck configuration.
# Keep this minimal: only silence noisy info-level codes so that
# warning/error findings stay visible. CI gates on --severity=warning.

# Sourced files (e.g. scripts/lib.sh) are resolved from provider runtime
# plugin roots; ShellCheck cannot follow those dynamic paths statically.
disable=SC1091

# Single-quoted $-expressions are intentional throughout (awk/jq/tmux
# format strings that must not expand in the shell).
disable=SC2016
